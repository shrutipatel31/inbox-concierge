# Google OAuth (from Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Gemini API key (free from Google AI Studio, no card). Used from M3.
GEMINI_API_KEY=

# Auth.js session secret. Generate with: npx auth secret  (or: openssl rand -base64 32)
NEXTAUTH_SECRET=

# Base URL of the app (used by Auth.js for OAuth callbacks).
NEXTAUTH_URL=http://localhost:3000
